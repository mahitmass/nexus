# ============================================================
# Project Nexus — Environment Variables
# Copy to .env.local (web) and .env (services)
# NEVER commit actual secrets.
# ============================================================

# ── Theme ────────────────────────────────────────────────────
# Change to: agriculture | healthcare | fintech
DOMAIN_THEME=generic

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://nexus:nexus_secret@localhost:5432/nexus
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret

MONGO_URI=mongodb://nexus:nexus_secret@localhost:27017/nexus_logs
MONGO_USER=nexus
MONGO_PASSWORD=nexus_secret

REDIS_URL=redis://:nexus_secret@localhost:6379
REDIS_PASSWORD=nexus_secret

# ── Auth — Clerk (preferred) ──────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE
CLERK_SECRET_KEY=sk_test_REPLACE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Auth — NextAuth (alternative) ────────────────────────────
NEXTAUTH_SECRET=REPLACE_WITH_OPENSSL_RAND
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=REPLACE
GOOGLE_CLIENT_SECRET=REPLACE
GITHUB_CLIENT_ID=REPLACE
GITHUB_CLIENT_SECRET=REPLACE

# ── AI & LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE
ANTHROPIC_API_KEY=sk-ant-REPLACE
HUGGINGFACE_API_KEY=hf_REPLACE

# ── Vector Store ─────────────────────────────────────────────
PINECONE_API_KEY=REPLACE
PINECONE_INDEX=nexus-index
PINECONE_ENVIRONMENT=us-east-1-aws

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE
SUPABASE_SERVICE_ROLE_KEY=REPLACE

# ── Firebase ─────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE

# ── Payments ─────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ── Communications ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE
TWILIO_AUTH_TOKEN=REPLACE
TWILIO_PHONE_NUMBER=+1REPLACE

SENDGRID_API_KEY=SG.REPLACE
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Media ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REPLACE
CLOUDINARY_API_KEY=REPLACE
CLOUDINARY_API_SECRET=REPLACE

# ── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexus-assets

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=https://REPLACE@REPLACE.ingest.sentry.io/REPLACE
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE@REPLACE.ingest.sentry.io/REPLACE
DATADOG_API_KEY=REPLACE

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_64
JWT_EXPIRES_IN=7d

# ── gRPC ─────────────────────────────────────────────────────
GRPC_PORT=4001
AI_SERVICE_GRPC_URL=localhost:50051

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
