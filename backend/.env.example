# PrahaariNet — Environment config
# Copy this file to .env and fill in your credentials.

# --- Neo4j Aura (required — sign up at console.neo4j.io) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# --- Model paths (leave as default) ---
MODEL_PATH=models/elliptic_graphsage.pt
ISO_PATH=models/iso_forest.pkl

# --- Bhashini (optional — app falls back to Web Speech if absent) ---
# Register at bhashini.gov.in — 24hr activation window, do this EARLY
BHASHINI_KEY=
BHASHINI_UDYAT=

# --- WhatsApp Business Cloud API (optional) ---
# developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
